<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaoyua.mapper.jNotificationMapper">

    <!-- 通知VO结果映射 -->
    <resultMap id="NotificationVOMap" type="com.xiaoyua.vo.notification.NotificationVO">
        <id column="id" property="id"/>
        <result column="type" property="type"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="ref_id" property="refId"/>
        <result column="ref_type" property="refType"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="count" property="count"/>

        <!-- 发送者用户信息 -->
        <association property="fromUser" javaType="com.xiaoyua.vo.user.UserSimpleVO">
            <id column="from_user_id" property="id"/>
            <result column="from_user_nickname" property="nickname"/>
            <result column="from_user_avatar_url" property="avatarUrl"/>
            <result column="from_user_gender" property="gender"/>
            <result column="from_user_campus_id" property="campusId"/>
            <result column="from_user_is_real_name" property="isRealName"/>
            <result column="from_user_created_at" property="createdAt"/>
        </association>
    </resultMap>

    <!-- 分页查询通知列表（联表查询用户信息） -->
    <select id="selectNotificationsWithUser" resultMap="NotificationVOMap">
        SELECT
        n.id,
        n.type,
        n.title,
        n.content,
        n.ref_id,
        n.ref_type,
        n.status,
        n.created_at,
        1 as count,
        u.id as from_user_id,
        u.nickname as from_user_nickname,
        u.avatar_url as from_user_avatar_url,
        u.gender as from_user_gender,
        u.campus_id as from_user_campus_id,
        u.is_real_name as from_user_is_real_name,
        u.created_at as from_user_created_at
        FROM notifications n
        LEFT JOIN users u ON n.from_user_id = u.id
        WHERE n.user_id = #{userId}
        <if test="type != null and type != ''">
            AND n.type = #{type}
        </if>
        ORDER BY n.created_at DESC
    </select>

</mapper>
